# Google Spreadsheet-ID (publikt ark, "alla med länken kan visa")
SHEET_ID=1NlUCIKlLgaWAmGq4UKAcCAvzuwwKdMGLkDiWh7ZFoeY

# Port (sätts av Render i produktion)
PORT=3000

# Hur ofta servern hämtar facit (Resultat) och deltagarlistan, i sekunder
SHEET_REFRESH_SECONDS=15

# Hur ofta klienten pollar /api/standings, i sekunder
CLIENT_POLL_SECONDS=5

# Hur ofta deltagarflikarna (tipsen) hämtas om, i sekunder.
# Tipsen är låsta efter turneringsstart, så detta kan vara glest.
PREDICTIONS_REFRESH_SECONDS=300

# --- Live-resultat under match (överlägg, arket vinner alltid) ---------------
# Leverantör: 'worldcup26' (gratis community-API, kräver LIVE_TOKEN), 'mock'
# (lokal testning), eller 'none' (av). Om LIVE_MOCK är satt väljs mock automatiskt.
# LIVE_PROVIDER=worldcup26

# Hur ofta live-snapshot hämtas, i sekunder. Servern pollar bara inom en
# matchs live-fönster (avspark → +2.25 h) för riktiga leverantörer.
LIVE_REFRESH_SECONDS=15

# Stäng av live helt med 'false'.
# LIVE_ENABLED=true

# worldcup26: bas-URL och Bearer-token (gratis registrering på worldcup26.ir).
# LIVE_BASE_URL=https://worldcup26.ir
# LIVE_TOKEN=

# Lokal testning utan riktig match: injicera en låtsas-livematch.
# Format: "Hemma|Borta MÅL-MÅL MINUT" (MINUT = siffra för pågående, FT = slut).
# Flera matcher separeras med semikolon. Exempel:
# LIVE_MOCK=Belgien|Iran 2-1 67
